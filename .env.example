# ============================================
# Authentication Secrets
# ============================================
# REQUIRED: Secret key for signing access tokens (use a strong random string)
ACCESS_TOKEN_SECRET=your-super-secret-access-token-key-here

# ============================================
# Apple OAuth Configuration
# ============================================
# REQUIRED: Apple P8 private key (base64 encoded)
# Get this from Apple Developer Console
APPLE_P8=your-base64-encoded-apple-p8-key-here

# OPTIONAL: Apple credentials (defaults in constants.ts for backward compatibility)
APPLE_KEY_ID=V7SW4ZQ46G
APPLE_CLIENT_ID=app.alice.learn
APPLE_TEAM_ID=A98NTM7WMG

# ============================================
# Google OAuth Configuration
# ============================================
# REQUIRED: Google OAuth client ID
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# REQUIRED: Google OAuth client secret
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# OPTIONAL: Google redirect URI (default: http://localhost:3000/google-oauth)
GOOGLE_REDIRECT_URI=http://localhost:3000/google-oauth

# ============================================
# Email Configuration (SendGrid)
# ============================================
# REQUIRED: SendGrid API key for sending emails
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here

# OPTIONAL: Email address to use as sender (defaults to noreply@yourdomain.com)
EMAIL_SENDER=alice@appalice.com

# ============================================
# Redis Configuration
# ============================================
# REQUIRED: Redis host (use 'redis' for Docker, 'localhost' for local)
REDIS_HOST=redis

# ============================================
# Database Configuration
# ============================================
# REQUIRED: Main database connection string
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname
#
# For DigitalOcean Managed Database:
# DATABASE_URL=postgresql://doadmin:AVNS_...@db-postgresql-nyc1-....db.ondigitalocean.com:25060/defaultdb?sslmode=require

# OPTIONAL: Test database connection string (for running tests)
# If not set, tests will use DATABASE_URL
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname_test

# ============================================
# Cache Configuration
# ============================================
# OPTIONAL: Cache key namespace (default: 'prisma')
# CACHE_NAMESPACE=prisma

# OPTIONAL: Default cache TTL in seconds (default: 60 in production, 3 in test)
# CACHE_DEFAULT_TTL=60

# OPTIONAL: Default stale-while-revalidate time in seconds (default: 10 in production, 1 in test)
# CACHE_DEFAULT_STALE_TIME=10

# OPTIONAL: Use memory cache as fallback if Redis fails (default: true)
# CACHE_MEMORY_FALLBACK=true

# OPTIONAL: Maximum items in memory fallback cache (default: 1000)
# CACHE_MEMORY_MAX_ITEMS=1000
