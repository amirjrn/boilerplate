  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "attach",
      "name": "Bob: Attach",
      "port": 9229,
      "address": "localhost",
      "restart": true,
      "protocol": "inspector",
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "localRoot": "${workspaceFolder}/dist",
      "remoteRoot": "/app/dist" // Because dev docker is using the same dist folder as ours with docker volumes
