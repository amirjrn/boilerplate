# =============================================================================
# TERRAFORM VARIABLES - EXAMPLE
# =============================================================================
# Copy this file to terraform.tfvars and fill in your values.
# NEVER commit terraform.tfvars to version control!
# =============================================================================

# DigitalOcean API Token (generate at https://cloud.digitalocean.com/account/api/tokens)
do_token = "dop_v1_your_token_here"

# Cloudflare API Token (generate at https://dash.cloudflare.com/profile/api-tokens)
# Required permissions: Account > R2 > Edit
cloudflare_api_token = "your_cloudflare_api_token_here"

# Cloudflare Account ID (find at https://dash.cloudflare.com -> any zone -> Overview -> right sidebar)
cloudflare_account_id = "your_account_id_here"

# -----------------------------------------------------------------------------
# GitHub Configuration (for automatic secret management)
# -----------------------------------------------------------------------------
# Generate a Personal Access Token at: https://github.com/settings/tokens
# Required scopes: repo, admin:org (if using an organization)

github_token = "ghp_your_github_personal_access_token_here"
github_owner = "your-github-username-or-org"
github_repo  = "Bob"

# SSH Key Fingerprint (find at https://cloud.digitalocean.com/account/security)
# This is for root access during droplet creation
ssh_key_fingerprint = "aa:bb:cc:dd:ee:ff:00:11:22:33:44:55:66:77:88:99"

# SSH Username - must match your GitHub secret SSH_USER
ssh_username = "deploy"

# SSH Public Key - paste your INFRA_PUBLIC_KEY content here
ssh_public_key = "ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAAB... your-key-here"

# Application name (used for naming all resources)
app_name = "bob"

# Environment
environment = "production"

# -----------------------------------------------------------------------------
# Droplet Configuration
# -----------------------------------------------------------------------------

# Droplet size (https://slugs.do-api.dev/)
droplet_size = "s-1vcpu-1gb"

# Droplet image (use 'docker-20-04' for Docker pre-installed)
droplet_image = "docker-20-04"

# Regions for droplets
regions = {
  eu   = "fra1"  # Frankfurt
  na   = "nyc1"  # New York
  asia = "sgp1"  # Singapore
  au   = "syd1"  # Sydney
}

# -----------------------------------------------------------------------------
# Cloudflare Load Balancer Configuration
# -----------------------------------------------------------------------------

# Cloudflare Zone ID (find at https://dash.cloudflare.com -> your domain -> Overview -> right sidebar)
cloudflare_zone_id = "your_zone_id_here"

# Hostname for the load balancer (must be a subdomain of your Cloudflare zone)
cloudflare_lb_hostname = "api.yourdomain.com"

# Email for health check notifications (optional)
cloudflare_notification_email = "alerts@yourdomain.com"

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------

# PostgreSQL cluster size
postgres_size = "db-s-1vcpu-1gb"

# PostgreSQL version
postgres_version = "15"

# PostgreSQL region
postgres_region = "fra1"

# Valkey cluster size
valkey_size = "db-s-1vcpu-1gb"

# Valkey region
valkey_region = "fra1"

# -----------------------------------------------------------------------------
# Container Registry Configuration
# -----------------------------------------------------------------------------

# Registry region
registry_region = "fra1"

# Registry subscription tier (basic, professional, or starter)
registry_subscription_tier = "basic"

# -----------------------------------------------------------------------------
# Cloudflare R2 Configuration
# -----------------------------------------------------------------------------

# R2 bucket name
r2_bucket_name = "bob-storage"
